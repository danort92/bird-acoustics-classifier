# Copy this file to .env and fill in your values.
# Never commit .env to git — it is already in .gitignore.

# ---------------------------------------------------------------------------
# Xeno-canto API (required for downloading recordings)
# Register at https://www.xeno-canto.org/article/854
# ---------------------------------------------------------------------------
XENO_CANTO_API_KEY=your_xeno_canto_api_key

# ---------------------------------------------------------------------------
# MLflow remote tracking via DagsHub (optional — local tracking works without these)
#
# 1. Create a free account at https://dagshub.com
# 2. Connect your repository
# 3. Find your token at https://dagshub.com/user/settings/tokens
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=https://dagshub.com/YOUR_USERNAME/bird-acoustics-classifier.mlflow
MLFLOW_TRACKING_USERNAME=YOUR_DAGSHUB_USERNAME
MLFLOW_TRACKING_PASSWORD=YOUR_DAGSHUB_TOKEN
